rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users collection - only authenticated users can access their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Vehicles collection - all authenticated users can read/write
    match /vehicles/{vehicleId} {
      allow read, write: if request.auth != null;
    }
    
    // Drivers collection - all authenticated users can read/write
    match /drivers/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    // Trips collection - all authenticated users can read/write
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }
    
    // Maintenance collection - all authenticated users can read/write
    match /maintenance/{maintenanceId} {
      allow read, write: if request.auth != null;
    }
    
    // FuelLogs collection - all authenticated users can read/write
    match /fuelLogs/{fuelLogId} {
      allow read, write: if request.auth != null;
    }
    
    // Expenses collection - all authenticated users can read/write
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null;
    }
    
    // Notifications collection - all authenticated users can read/write
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
  }
}
